programa {
  funcao inicio() {
    cadeia time
    escreva("### Times ###")
    escreva("\nDigite algum time do Futebol Brasileiro: ")
    leia(time)
    
    escolha (time) {
      caso "São Paulo":
      escreva("O time é de São Paulo")
      pare
      caso "Palmeiras":
      escreva("O time é de São Paulo")
      pare
      caso "Santos":
      escreva("O time é de São Paulo")
      pare
      caso "Corinthians":
      escreva("O time é de São Paulo")
      pare
      caso "Flamengo":
