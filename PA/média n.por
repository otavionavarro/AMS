programa {
  funcao inicio() {
    real n1, n2, n3, n4, resultado

    escreva("digite n1: ")
    leia(n1)
    escreva("digite n2: ")
    leia(n2)
    escreva("digite n3: ")
    leia(n3)
    escreva("digite n4: ")
    leia(n4)

    resultado=(n1+n2+n3+n4)/4
    escreva("a média é:",resultado)
  }
}
