programa {
  funcao inicio() {
    inteiro altura_dos_degraus, altura_desejada, resultado

    escreva("Digite a altura desejada: ")
    leia(altura_desejada)
    escreva("Digite a altura dos degraus: ")
    leia(altura_dos_degraus)

    resultado=altura_desejada/altura_dos_degraus

    escreva("A quantidade de degraus é: ", resultado)
    
  }
}
